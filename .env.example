# ==============================================================
# .env.example — 凭证变量名模板（进 git，不含真实值）
# 用法：cp .env.example .env 后填入真实值。.env 永不进 git。
# 本站为纯静态站，以下均为“公开级”标识（非私密密钥），
# 但仍走 .env 以免把账号 ID 直接写死进源码。
# Astro 约定：PUBLIC_ 前缀的变量才会注入到浏览器端。
# ==============================================================

# Formspree 联系表单端点 ID（站长在 formspree.io 建表单后获得，形如 xdorwkpe）
# 用途：联系表单 POST 到 https://formspree.io/f/<ID> → 转发到站长邮箱
PUBLIC_FORMSPREE_ID=

# Google Analytics 4 测量 ID（公开值，形如 G-XXXXXXXXXX）
# 缺省时站点仍正常渲染，仅不发送分析事件（静默失败）
PUBLIC_GA4_MEASUREMENT_ID=

# 站长联系邮箱（Formspree 不可用时，前端降级为 mailto: 链接）
PUBLIC_CONTACT_EMAIL=
