---
// Plan My Trip 服务页（F054，商业化入口，人工接单）：dates/party size/needs 专属表单，
// 提交/降级逻辑见 TripPlanForm（同 ContactForm 的 F027 Formspree/mailto 模式）。
import BaseLayout from '../layouts/BaseLayout.astro';
import TripPlanForm from '../components/TripPlanForm.astro';
---
<BaseLayout
  title="Plan My Trip — No Visa China"
  description="Tell us your dates and what you want in Guangxi — hotels, tickets, a custom route. We reply with a quote, no online payment."
>
  <main>
    <article class="plan">
      <h1>Plan My Trip</h1>
      <p class="lead">
        Tell us your dates, group size, and what you want. We help with hotels,
        tickets, and a custom route — then reply with a plan and a price.
      </p>
      <p class="note">No online payment, no auto-pricing — a real reply from a real person.</p>
      <TripPlanForm />
    </article>
  </main>
</BaseLayout>

<style>
  .plan {
    max-width: 640px;
  }
  .plan h1 {
    margin-bottom: 12px;
  }
  .lead {
    font-size: 1.0625rem;
    color: var(--ink);
  }
  .note {
    margin-top: 8px;
    font-size: 0.875rem;
    color: var(--muted);
  }
</style>
