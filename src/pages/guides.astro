---
// 攻略列表页（F020）：按区域分组渲染攻略卡片；无文章的区域显示空状态。
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';

// 阅读时长：正文词数 / 200，向上取整，至少 1 分钟（F011 说明，确定性计算）。
function readingMinutes(body: string): number {
  const words = (body.replace(/[#*_`>\-\[\]()!]/g, ' ').match(/\S+/g) ?? []).length;
  return Math.max(1, Math.round(words / 200));
}

// 固定区域顺序：即使无文章也按此顺序渲染（F020 说明）。
const REGION_ORDER = ['Beihai & Weizhou', 'Border Towns', 'Inland Karst'] as const;

const guides = await getCollection('guides');
const cards = guides.map((entry) => ({
  title: entry.data.title,
  summary: entry.data.summary,
  region: entry.data.region,
  cover: entry.data.cover,
  href: `/guides/${entry.data.slug ?? entry.id}/`,
  readingMinutes: readingMinutes(entry.body ?? ''),
}));

// 按区域分组：canonical 桶用固定顺序；未匹配的区域归入「Other」。
type Card = (typeof cards)[number];
const grouped = new Map<string, Card[]>();
for (const region of REGION_ORDER) grouped.set(region, []);
for (const card of cards) {
  if (!grouped.has(card.region)) grouped.set(card.region, []);
  grouped.get(card.region)!.push(card);
}

const sections = Array.from(grouped.entries()).map(([region, items]) => ({ region, items }));
---
<BaseLayout
  title="Guides — No Visa China"
  description="City-by-city travel guides for Guangxi, researched and verified on the ground."
>
  <main>
    <h1>Guides</h1>
    {sections.map(({ region, items }) => (
      <section class="guide-region">
        <h2 class="guide-region__heading">{region}</h2>
        {items.length === 0 ? (
          <div class="guide-empty">
            <p class="guide-empty__title">Guides in the works</p>
            <p class="guide-empty__sub">We're researching this region on the ground. Check back soon.</p>
          </div>
        ) : (
          <div class="guide-grid">
            {items.map((card) => <GuideCard {...card} />)}
          </div>
        )}
      </section>
    ))}
  </main>
</BaseLayout>

<style>
  .guide-region {
    margin-top: 40px;
  }
  .guide-region__heading {
    color: var(--ink);
    font-size: 1.375rem;
    margin: 0 0 16px;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  /* 空状态：虚线框 + 透明底，故意不用 primary-soft——避免和照片占位块撞色，
     导致整页看起来像同一块蓝底重复拼贴（视觉打磨发现）。无阴影、直角（DESIGN.md 北欧极简）。 */
  .guide-empty {
    background: transparent;
    border: 1px dashed var(--border);
    padding: 24px;
  }
  .guide-empty__title {
    color: var(--muted);
    font-weight: 600;
    margin: 0;
  }
  .guide-empty__sub {
    color: var(--muted);
    font-size: 0.875rem;
    margin: 4px 0 0;
  }
</style>
