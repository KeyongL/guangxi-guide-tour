---
// 首页（F058，方向 B3「Two-page」，对标 mockups/12-b3-home-two-page.html）：
// 站长否掉方向 B 全量版后做减法（DESIGN.md 方向锁定 B2 块 + 7 条负面清单）。
// 结构砍到 3 屏：全宽照片 Hero（单 CTA "Check my passport →"）→ 真实地图 + 两条
// 路线入口（F051 红线）→ 护照三行速查（CTA 落点，含 ⚠ 警示态）→ 页脚。
// 删（相对方向 B）：一句话信任线自夸、6 张城市卡片墙、Latest guides 信息流、
// 底部二次 CTA 横幅、visa-lanes 详表——负面清单 #1/#2/#3/#7。
// 保留 SPEC 红线：色彩令牌、纯英文 UI/仅地名双语、术语人话化（F052）、渐进增强
// （地图 F028 降级见 RouteMap.astro）、Dongxing 陆路出境「未核实」态。
import BaseLayout from '../layouts/BaseLayout.astro';
import RouteMap from '../components/RouteMap.astro';

// 地图途经点（F059）：真实经纬度，按行程顺序补齐两条路线的途经站；
// group 决定归属哪个可开关图层；photo 是弹窗照片占位槽的图注（待站长实拍替换）。
// 路线折线几何在 src/data/route-geometry.json（真实公路，OSRM 一次性抓取）。
type StopGroup = 'coastal' | 'border' | 'both' | 'vietnam';
const stops: { name: string; lat: number; lng: number; sub?: string; href?: string; group: StopGroup; photo?: string; note?: string }[] = [
  { name: 'Nanning 南宁', lat: 22.817, lng: 108.3665, sub: 'Fly-in port · 10-day transit OK', href: '/itineraries/flow-a/', group: 'both', photo: 'Yongjiang riverside' },
  { name: 'Beihai 北海', lat: 21.4733, lng: 109.1209, sub: 'Fly-in port · coast · 2–3 days', href: '/itineraries/flow-a/', group: 'coastal', photo: 'Silver Beach' },
  { name: 'Weizhou Island 涠洲岛', lat: 21.0333, lng: 109.1167, sub: 'Ferry from Beihai · 1–2 days', href: '/guides/weizhou-island-complete-guide/', group: 'coastal', photo: 'Volcanic sea cliffs' },
  { name: 'Fangchenggang 防城港', lat: 21.6867, lng: 108.3547, sub: 'Harbour coast · day stop', href: '/itineraries/flow-a/', group: 'coastal', photo: 'Fishing harbour' },
  { name: 'Dongxing 东兴', lat: 21.5433, lng: 108.0064, sub: 'Border bridge · walk across ~15 min', href: '/itineraries/flow-a/', group: 'coastal', photo: 'Border gate', note: 'Entry here: 30-day list or visa — 10-day transit must fly in' },
  { name: 'Detian Falls 德天瀑布', lat: 22.8564, lng: 106.7204, sub: 'Transnational waterfall · visa required', href: '/guides/detian-waterfall-friendship-pass/', group: 'border', photo: 'Detian waterfall' },
  { name: 'Jingxi 靖西', lat: 23.1347, lng: 106.4173, sub: 'Tongling canyon · visa required', href: '/itineraries/flow-b/', group: 'border', photo: 'Tongling Grand Canyon' },
  { name: 'Baise 百色', lat: 23.9022, lng: 106.6183, sub: 'Karst west hub · visa required', href: '/itineraries/flow-b/', group: 'border', photo: 'Riverside old quarter' },
  { name: 'Leye 乐业', lat: 24.7833, lng: 106.5611, sub: 'Dashiwei sinkholes · visa required', href: '/guides/leye-tiankeng-baise/', group: 'border', photo: 'Dashiwei tiankeng' },
  { name: 'Bama 巴马 · Hechi 河池', lat: 24.1414, lng: 107.2547, sub: 'Longevity karst · caves', href: '/guides/bama-longevity-hechi/', group: 'border', photo: 'Karst valleys' },
  // 从越南过来（F060）：时长/班次未实地核实的一律挂 not yet verified；公司名不编造——代订走 Plan My Trip。
  { name: 'Hanoi', lat: 21.0285, lng: 105.8542, sub: 'Buses to the border · from HCMC fly ~2 h', note: 'Bus to Nanning ~8 h · to Móng Cái ~5 h — not yet verified', href: '/plan-my-trip/', group: 'vietnam' },
  { name: 'Ha Long Bay', lat: 20.9517, lng: 107.0805, sub: 'Cruise hub · on the Móng Cái road', note: 'Bus to Móng Cái ~4 h — not yet verified', group: 'vietnam' },
  { name: 'Móng Cái', lat: 21.5333, lng: 107.9667, sub: 'Walk the bridge into Dongxing ~15 min', note: 'Entry: 30-day list or visa — 10-day transit must fly in', href: '/guides/vietnam-to-china-overland/', group: 'vietnam' },
  { name: 'Friendship Pass 友谊关', lat: 21.9743, lng: 106.7146, sub: 'Hanoi–Nanning road crossing', note: 'Entry: 30-day list or visa — 10-day transit must fly in', href: '/guides/detian-waterfall-friendship-pass/', group: 'vietnam' },
];
---
<BaseLayout
  title="Vietnam, Laos, Cambodia — and Guangxi | No Visa China"
  description="Detour into China's south — 10 visa-free days in Guangxi, then walk into Vietnam."
>
  <!-- HERO：全宽照片占位 + 一句话主张 + 单一 CTA（负面清单 #1 无信任条、#2 一屏一动作） -->
  <section class="photo-hero">
    <div class="photo-hero__inner">
      <h1>Vietnam, Laos, Cambodia —<br />and Guangxi.</h1>
      <p class="sub">Detour into China's south. 10 days, no visa.</p>
      <a class="cta-btn" href="#check">Check my passport →</a>
    </div>
    <!-- 负面清单 #5：占位不用喊话式大字，降为角落小字 -->
    <span class="photo-hero__note">photo: coastal cliffs / border gate — real photography required</span>
  </section>

  <main>
    <!-- 第二屏：真实地图（F051）+ 两条路线入口。不铺城市卡片墙（负面清单 #3） -->
    <section class="the-route">
      <h2>The route</h2>
      <RouteMap
        stops={stops}
        label="Map of Guangxi showing the coastal route and the border loop"
      />
      <ul class="lanes">
        <li><a href="/itineraries/flow-a/">
          <span class="name">The coastal route</span>
          <span class="meta">3–5 days · no visa</span>
        </a></li>
        <li><a href="/itineraries/flow-b/">
          <span class="name">The border loop</span>
          <span class="meta">7–10 days · visa required</span>
        </a></li>
        <li><a href="/guides/vietnam-to-china-overland/">
          <span class="name">Getting in from Vietnam</span>
          <span class="meta">Hanoi / Ha Long buses · land entry: 30-day list or visa</span>
        </a></li>
      </ul>
    </section>

    <!-- CTA 落点：护照三行速查，政策数字收在这里（负面清单 #7），含 ⚠ 警示态 -->
    <section class="check" id="check">
      <h2>Do you need a visa?</h2>
      <div class="lane-row ok">
        <span class="tick">✓</span>
        <span><b>US, UK, Canada +50</b> — 10 days, no visa.</span>
      </div>
      <div class="lane-row ok">
        <span class="tick">✓</span>
        <span><b>EU, Australia, NZ +40</b> — 30 days, no visa.</span>
      </div>
      <div class="lane-row warn">
        <span class="tick">⚠</span>
        <span><b>Neither</b> — visa required.</span>
      </div>
      <p class="fine">
        Checked 20 Jun 2026 · confirm with the
        <a href="https://en.nia.gov.cn/" target="_blank" rel="noopener noreferrer">NIA</a>.
        <span class="unverified">Dongxing land exit: unverified.</span>
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  /* 方向 B2「Focused」：色彩令牌不变（SPEC 红线），做减法。全宽照片 Hero + 真地图 + 护照速查。 */

  /* ── Photo hero（全宽，不受 main 1100px 约束） ── */
  .photo-hero {
    position: relative;
    min-height: 72svh;
    display: flex;
    align-items: flex-end;
    background: linear-gradient(180deg, var(--primary-soft) 0%, var(--primary) 150%);
    border-bottom: 1px solid var(--border);
  }
  .photo-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    padding: 48px 20px 46px;
    color: #fff;
  }
  .photo-hero h1 {
    color: #fff;
    font-weight: 650;
    letter-spacing: -0.01em;
    line-height: 1.12;
    font-size: clamp(1.875rem, 5.5vw, 3.25rem);
    margin: 0 0 12px;
    max-width: 24ch;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.35);
  }
  .photo-hero .sub {
    font-size: 1.0625rem;
    max-width: 44ch;
    margin: 0 0 24px;
    opacity: 0.94;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.3);
  }
  .photo-hero .cta-btn {
    display: inline-block;
    background: var(--accent);
    color: #231400;
    font-weight: 650;
    text-decoration: none;
    padding: 14px 26px;
    font-size: 1rem;
    border: 1px solid var(--accent);
  }
  .photo-hero .cta-btn:hover {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
  }
  .photo-hero__note {
    position: absolute;
    right: 14px;
    bottom: 10px;
    color: #fff;
    opacity: 0.5;
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
  }

  /* ── The route（真地图 + 两条路线入口） ── */
  .the-route { margin-top: 8px; }
  .the-route h2 { font-size: 1.375rem; margin: 0 0 14px; }
  .lanes { list-style: none; margin: 16px 0 0; padding: 0; }
  .lanes li { border: 1px solid var(--border); background: var(--surface); margin-bottom: 10px; }
  .lanes a {
    display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap;
    padding: 14px 16px; color: var(--text); text-decoration: none;
  }
  .lanes a:hover { border-color: var(--primary); color: var(--primary); }
  .lanes .name { font-weight: 650; color: var(--ink); }
  .lanes .meta { color: var(--muted); font-size: 0.875rem; }

  /* ── Passport quick-check（CTA 落点，3 行） ── */
  .check { margin-top: 44px; scroll-margin-top: 16px; }
  .check h2 { font-size: 1.375rem; margin: 0 0 16px; }
  .lane-row {
    display: flex; gap: 10px; align-items: flex-start;
    border: 1px solid var(--border); background: var(--surface);
    padding: 13px 16px; margin-bottom: 10px; font-size: 0.9375rem;
  }
  .lane-row .tick { flex: 0 0 auto; font-weight: 650; }
  .lane-row.ok .tick { color: var(--ok-text); }
  .lane-row.warn {
    background: var(--warn-bg); border-left: 3px solid var(--warn-border); color: var(--warn-text);
  }
  .lane-row.warn .tick { color: var(--warn-text); }
  .lane-row b { color: var(--ink); }
  .lane-row.warn b { color: inherit; }
  .fine { color: var(--muted); font-size: 0.8125rem; margin: 14px 0 0; }
  .fine a { color: var(--primary); }
  .fine .unverified { color: var(--accent-strong); font-style: italic; }

  @media (max-width: 768px) {
    .photo-hero { min-height: 62svh; }
  }
</style>
