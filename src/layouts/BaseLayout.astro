---
// 基础布局（F003）：全局令牌 CSS + 深色模式（跟随系统 + 手动切换覆盖）。
// head 复用 BaseHead（F004 唯一 title/description，内部已含 GoogleAnalytics）。
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Anti-flicker: apply manual theme before render; fall back to CSS system preference when unset.
      (function () {
        var t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <header class="site-header">
      <!-- B3 负面清单#8：品牌词退出 UI——home 用无字地图钉图标，品牌只留 <title> 后缀与域名。 -->
      <a class="brand" href="/" aria-label="Home">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <circle cx="12" cy="10" r="3" />
          <path d="M12 21c4.5-4.7 7-8 7-11a7 7 0 1 0-14 0c0 3 2.5 6.3 7 11Z" />
        </svg>
      </a>
      <nav class="site-nav" aria-label="Main">
        <a class="site-nav__cta" href="/plan-my-trip/">Plan My Trip</a>
      </nav>
      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme">Dark</button>
    </header>
    <slot />
    <footer class="site-footer">
      <!-- B3 页脚一行制：叶子页入口 + NIA 合规指针（词预算：一行）。 -->
      <nav class="footer-nav" aria-label="Sitemap">
        <a href="/guides/">Guides</a>
        <a href="/about/">About</a>
      </nav>
      <p class="footer-disclaimer">
        Rules change — verify with the
        <a href="https://en.nia.gov.cn/" target="_blank" rel="noopener noreferrer">NIA</a>.
      </p>
    </footer>
    <script>
      const btn = document.getElementById('theme-toggle');
      const media = window.matchMedia('(prefers-color-scheme: dark)');

      function currentTheme(): 'light' | 'dark' {
        const manual = document.documentElement.getAttribute('data-theme');
        if (manual === 'light' || manual === 'dark') return manual;
        return media.matches ? 'dark' : 'light';
      }

      function updateLabel() {
        if (btn) btn.textContent = currentTheme() === 'dark' ? 'Light' : 'Dark';
      }

      btn?.addEventListener('click', () => {
        const next = currentTheme() === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateLabel();
      });
      media.addEventListener('change', updateLabel);
      updateLabel();
    </script>
    <style>
      .site-footer {
        max-width: 1100px;
        margin: 0 auto;
        padding: 20px 24px 28px;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.8125rem;
        line-height: 1.6;
        display: flex;
        flex-wrap: wrap;
        gap: 12px 24px;
        justify-content: space-between;
        align-items: baseline;
      }
      .footer-disclaimer {
        margin: 0;
      }
      .site-footer a { color: var(--primary); }
      .site-footer a:hover { color: var(--primary-strong); }
      .footer-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 24px;
      }
    </style>
  </body>
</html>
