---
// 联系表单组件（F015 UI 层 + F027 降级）：Name / Email / Message + 提交成功占位态。
// F027：Formspree id 缺失/不可用/提交失败时，降级为可见的 mailto: 链接（站长邮箱来自 env）。
// env 读取遵循 Astro 约定（见 GoogleAnalytics.astro）：import.meta.env.PUBLIC_*。
// 校验走原生 HTML5 required + type="email"；提交用 fetch 拦截，同页面切态（成功/回退二选一）。
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL;
const formspreeEndpoint = formspreeId ? `https://formspree.io/f/${formspreeId}` : '';
---
<section class="contact" aria-labelledby="contact-heading">
  <h2 id="contact-heading">Contact</h2>
  <form class="contact-form" data-formspree-endpoint={formspreeEndpoint} novalidate={false}>
    <label class="field">
      <span>Name</span>
      <input type="text" name="name" required />
    </label>
    <label class="field">
      <span>Email</span>
      <input type="email" name="email" required />
    </label>
    <label class="field">
      <span>Message</span>
      <textarea name="message" rows="4" required></textarea>
    </label>
    <button type="submit">Send</button>
  </form>
  <div class="contact-success" hidden>
    <p>Thanks — I'll reply within 24h.</p>
  </div>
  {contactEmail ? (
    <p class="contact-fallback" hidden>
      Prefer email? Reach me at <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
    </p>
  ) : (
    <p class="contact-fallback" hidden>
      Sorry — this form isn't available right now.
    </p>
  )}
</section>

<script>
  // F027：有 endpoint 才真正 fetch POST；无 endpoint、网络错误、非 2xx 响应
  // 都算失败，一律走 mailto 回退（或无邮箱时的诚实占位文案），不假装成功。
  // 成功/回退二选一，表单先隐藏再二选一显示，不会同屏矛盾。
  const form = document.querySelector<HTMLFormElement>('.contact-form');
  const success = document.querySelector<HTMLElement>('.contact-success');
  const fallback = document.querySelector<HTMLElement>('.contact-fallback');

  function showSuccess() {
    if (form) form.hidden = true;
    if (success) success.hidden = false;
  }

  function showFallback() {
    if (form) form.hidden = true;
    if (fallback) fallback.hidden = false;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const endpoint = form.dataset.formspreeEndpoint;
    if (!endpoint) {
      showFallback();
      return;
    }
    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });
      if (res.ok) {
        showSuccess();
      } else {
        showFallback();
      }
    } catch {
      showFallback();
    }
  });
</script>

<style>
  /* 北欧极简：直角、1px 细线、留白；色值全用全局令牌。 */
  .contact {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
    max-width: 480px;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 16px;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .field span {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink);
  }
  .field input,
  .field textarea {
    font: inherit;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0;
    padding: 10px 12px;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--primary);
  }
  .field textarea {
    resize: vertical;
  }
  button[type='submit'] {
    align-self: flex-start;
    background: var(--primary);
    color: var(--surface);
    border: 1px solid var(--primary);
    border-radius: 0;
    font: 600 0.875rem/1 var(--sans);
    padding: 10px 20px;
    cursor: pointer;
  }
  button[type='submit']:hover {
    background: var(--primary-strong);
    border-color: var(--primary-strong);
  }
  .contact-success {
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--success-bg);
    color: var(--success-text);
    font-size: 0.875rem;
  }
  .contact-fallback {
    margin-top: 16px;
    font-size: 0.875rem;
    color: var(--text);
  }
  .contact-fallback a {
    color: var(--primary);
  }
</style>
