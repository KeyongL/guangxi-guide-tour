---
// 攻略卡片（F011）：扁平照片占位 + 区域标签 + 标题 + 摘要 + 阅读时长。
// 北欧极简：直角、1px 描边、无阴影；hover 描边变主色（DESIGN.md）。
// 颜色只引用 global.css 令牌，禁止硬编码 hex。
import PhotoPlaceholder from './PhotoPlaceholder.astro';
interface Props {
  title: string;
  summary: string;
  region: string;
  href: string;
  readingMinutes: number;
  cover?: string;
}
const { title, summary, region, href, readingMinutes, cover } = Astro.props;
---
<article class="guide-card">
  <PhotoPlaceholder caption={cover ?? 'Photo'} region={region} flush />
  <div class="guide-card__body">
    <span class="guide-card__region">{region}</span>
    <h3 class="guide-card__title">
      <a href={href}>{title}</a>
    </h3>
    <p class="guide-card__summary">{summary}</p>
    <p class="guide-card__meta">{readingMinutes} min read</p>
  </div>
</article>

<style>
  .guide-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    transition: border-color 0.15s ease;
  }
  .guide-card:hover {
    border-color: var(--primary);
  }

  .guide-card__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px;
  }

  .guide-card__region {
    align-self: flex-start;
    background: var(--primary-soft);
    color: var(--primary);
    border: 1px solid var(--primary);
    font: 600 0.6875rem/1.4 var(--sans);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
  }

  .guide-card__title {
    font-size: 1.1875rem;
  }
  .guide-card__title a {
    color: var(--ink);
  }
  .guide-card__title a:hover {
    color: var(--primary);
  }

  .guide-card__summary {
    color: var(--text);
    margin: 0;
  }

  .guide-card__meta {
    color: var(--muted);
    font-size: 0.8125rem;
    margin: 0;
  }
</style>
