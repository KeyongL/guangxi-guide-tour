---
// GA4 注入（F007）：measurement id 来自环境变量 PUBLIC_GA4_MEASUREMENT_ID。
// 非空字符串时注入标准 gtag.js 片段（异步加载 + 内联 config）；
// 为空 / 未定义时不注入任何脚本，页面仍正常渲染、构建不报错（静默失败）。
const measurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
---
{measurementId && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
    <script is:inline set:html={`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '${measurementId}');
    `} />
  </>
)}
