---
// 真实地图 v2（F059，继承 F051/F058 要求）：Leaflet + OSM 瓦片，无 API key。
// 路线折线 = 真实公路几何（src/data/route-geometry.json，OSRM 开发期一次性抓取，
// 运行期零路由 API）；渡轮段虚线；图层控件按路线开关（不同路线 = 不同游玩方案）；
// 标记弹窗 = 景点卡片（照片占位槽——站长实拍素材到位后替换，禁 AI 图红线）。
// 渐进增强（F028）：默认渲染文字站点列表；地图初始化成功才隐藏文字。
// 懒加载（F048）：IntersectionObserver 观察外层可见 wrap——勿观察 hidden 容器，
// display:none 元素永不触发 isIntersecting（907d951 教训）。
interface Stop {
  name: string;
  lat: number;
  lng: number;
  sub?: string;
  href?: string;
  group: 'coastal' | 'border' | 'both' | 'vietnam' | 'hechi';
  photo?: string;
  note?: string;
}
interface Props {
  stops: Stop[];
  label: string;
}
const { stops, label } = Astro.props;
---
<div class="route-map-wrap">
  <div
    id="route-map"
    class="route-map"
    aria-label={label}
    hidden
    data-stops={JSON.stringify(stops)}
  ></div>
  <div class="route-map__fallback" id="route-map-fallback">
    <div class="route-map__placeholder" role="img" aria-label={label}>
      <svg class="route-map__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
        <circle cx="7.5" cy="7.5" r="1.6"></circle>
        <path d="M3 17.5l5.5-6 4 3.7 3-3.2L21 17.5"></path>
      </svg>
      <span>Static route map — see stops below</span>
    </div>
    <ul class="route-map__stops">
      {stops.map((s) => (
        <li>
          {s.href ? <a href={s.href}>{s.name}</a> : <span>{s.name}</span>}
          {s.sub && <span class="sub"> — {s.sub}</span>}
        </li>
      ))}
    </ul>
  </div>
</div>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import geometry from '../data/route-geometry.json';

  interface StopData {
    name: string;
    lat: number;
    lng: number;
    sub?: string;
    href?: string;
    group: 'coastal' | 'border' | 'both' | 'vietnam' | 'hechi';
    photo?: string;
    note?: string;
  }

  function tokenColor(name: string): string {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }

  // 景点卡片弹窗：照片占位槽（站长实拍到位后替换）+ 双语地名 + 一句话 + 链接。
  function popupHtml(s: StopData): string {
    const photo = s.photo
      ? `<div class="rm-pop__photo"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><circle cx="7.5" cy="7.5" r="1.6"></circle><path d="M3 17.5l5.5-6 4 3.7 3-3.2L21 17.5"></path></svg><span>PHOTO — ${s.photo}</span></div>`
      : '';
    const sub = s.sub ? `<span class="rm-pop__sub">${s.sub}</span>` : '';
    // 时间/交通/入境规则一行（未实地核实的数字在数据里自带 not yet verified 标记，F032 规矩）。
    const note = s.note ? `<span class="rm-pop__note">${s.note}</span>` : '';
    const link = s.href ? `<a class="rm-pop__link" href="${s.href}">Details →</a>` : '';
    return `<div class="rm-pop">${photo}<strong>${s.name}</strong>${sub}${note}${link}</div>`;
  }

  function initMap(el: HTMLElement, fallback: HTMLElement) {
    try {
      // 先取消 hidden，让容器拿到 380px 高度再交给 Leaflet——
      // 对 display:none（高度 0）的容器 L.map() 会渲染出错位/空白地图。
      el.hidden = false;

      const stops = JSON.parse(el.dataset.stops ?? '[]') as StopData[];

      const primary = tokenColor('--primary') || '#0E7490';
      const accent = tokenColor('--accent') || '#F59E0B';
      const surface = tokenColor('--surface') || '#FFFFFF';
      // 红色 = 现有令牌 --error-text（浅 #B91C1C / 深 #F87171），不发明新色（SPEC 红线）。
      const red = tokenColor('--error-text') || '#B91C1C';
      // 绿色 = 现有令牌 --success-text（浅 #15803D / 深 #4ADE80），Route 3 河池自然线（F062）。
      const green = tokenColor('--success-text') || '#15803D';

      const map = L.map(el, { scrollWheelZoom: false });
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        maxZoom: 18,
      }).addTo(map);

      const marker = (s: StopData) =>
        L.circleMarker([s.lat, s.lng], {
          radius: 8,
          color: surface,
          weight: 2,
          fillColor: s.group === 'vietnam' ? red : s.group === 'hechi' ? green : accent,
          fillOpacity: 1,
        }).bindPopup(popupHtml(s), { maxWidth: 240 });

      // 白描边 + 加粗（站长反馈蓝黄不明显；OSM 瓦片恒为浅色底图，#FFFFFF 即浅色 --surface 值）。
      const casing = (pts: [number, number][]) =>
        L.polyline(pts, { color: '#FFFFFF', weight: 7, opacity: 0.9, interactive: false });
      const line = (pts: [number, number][], color: string, dashed?: boolean) =>
        L.polyline(pts, { color, weight: 4, dashArray: dashed ? '7 6' : undefined });
      const inGroup = (s: StopData, ...gs: string[]) => gs.includes(s.group);

      // 三个可开关图层 = 三套备选方案（各含自己的途经标记；Nanning 属 both，前两层各一份）。
      const coastal = L.layerGroup([
        casing(geometry.coastal as [number, number][]),
        line(geometry.coastal as [number, number][], primary),
        // 渡轮段（北海→涠洲岛，海路）：点状虚线，制图惯例。
        L.polyline(geometry.ferry as [number, number][], { color: primary, weight: 4, dashArray: '2 7' }),
        ...stops.filter((s) => inGroup(s, 'coastal', 'both')).map(marker),
      ]).addTo(map);
      const border = L.layerGroup([
        casing(geometry.border as [number, number][]),
        line(geometry.border as [number, number][], accent, true),
        ...stops.filter((s) => inGroup(s, 'border', 'both')).map(marker),
      ]).addTo(map);
      // 从越南入境（F060）：河内→友谊关→南宁；河内→下龙湾→芒街→东兴。红色，含时间/口岸弹窗。
      const vietnam = L.layerGroup([
        casing(geometry.vnNanning as [number, number][]),
        line(geometry.vnNanning as [number, number][], red),
        casing(geometry.vnDongxing as [number, number][]),
        line(geometry.vnDongxing as [number, number][], red),
        ...stops.filter((s) => inGroup(s, 'vietnam')).map(marker),
      ]).addTo(map);

      // 河池喀斯特 Route 3（F062）：真实公路环线连起原散布的 6 个河池标记；
      // 绿色（success 令牌）= 免签自然线，与蓝绿海岸线/琥珀边境线三色分明。
      const hechi = L.layerGroup([
        casing(geometry.hechiLoop as [number, number][]),
        line(geometry.hechiLoop as [number, number][], green),
        ...stops.filter((s) => inGroup(s, 'hechi')).map(marker),
      ]).addTo(map);

      L.control.layers(
        undefined,
        {
          'Route 1 · The Coast (visa-free)': coastal,
          'Route 2 · Border Karst (visa needed)': border,
          'Route 3 · Hechi Nature (visa-free)': hechi,
          'Getting in from Vietnam': vietnam,
        },
        { collapsed: false }
      ).addTo(map);

      // 容器刚从 hidden 变可见，强制重算尺寸后按全部路线+河池标记取景。
      map.invalidateSize();
      const all = ([] as [number, number][]).concat(
        geometry.coastal as [number, number][],
        geometry.border as [number, number][],
        geometry.vnNanning as [number, number][],
        geometry.vnDongxing as [number, number][],
        stops.filter((s) => inGroup(s, 'hechi')).map((s) => [s.lat, s.lng] as [number, number])
      );
      map.fitBounds(L.latLngBounds(all), { padding: [24, 24] });

      fallback.hidden = true;
    } catch {
      // 地图初始化失败：回退——重新隐藏地图容器，保持文字列表可见（F028）。
      el.hidden = true;
    }
  }

  // 观察「始终可见」的外层 wrap，而不是 hidden 的地图容器——
  // 对 display:none 元素 IntersectionObserver 永不触发 isIntersecting，
  // 这正是此前地图从不初始化、只显示文字回退的根因。
  const wrap = document.querySelector<HTMLElement>('.route-map-wrap');
  const mapEl = document.getElementById('route-map');
  const fallbackEl = document.getElementById('route-map-fallback');
  if (wrap && mapEl && fallbackEl) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            io.disconnect();
            initMap(mapEl, fallbackEl);
          }
        }
      },
      { rootMargin: '200px' }
    );
    io.observe(wrap);
  }
</script>

<style>
  .route-map-wrap {
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .route-map {
    height: 380px;
  }
  .route-map :global(.leaflet-popup-content-wrapper) {
    background: var(--surface);
    color: var(--text);
    border-radius: 0;
    font-family: var(--sans);
  }
  .route-map :global(.leaflet-popup-tip) {
    background: var(--surface);
  }
  .route-map :global(.leaflet-control-layers) {
    border-radius: 0;
    font-family: var(--sans);
  }
  /* 景点卡片弹窗（HTML 由脚本注入，需 :global） */
  .route-map :global(.rm-pop) {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .route-map :global(.rm-pop__photo) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    height: 84px;
    background: var(--primary-soft);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
  }
  .route-map :global(.rm-pop__photo svg) {
    width: 18px;
    height: 18px;
    opacity: 0.55;
  }
  .route-map :global(.rm-pop strong) {
    color: var(--ink);
    font-size: 0.9375rem;
  }
  .route-map :global(.rm-pop__sub) {
    color: var(--muted);
    font-size: 0.8125rem;
  }
  .route-map :global(.rm-pop__note) {
    color: var(--accent-strong);
    font-style: italic;
    font-size: 0.75rem;
  }
  .route-map :global(.rm-pop__link) {
    color: var(--primary);
    font-weight: 600;
    font-size: 0.8125rem;
  }
  .route-map__fallback {
    font-size: 0.875rem;
  }
  .route-map__placeholder {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 160px;
    background: var(--primary-soft);
    border-bottom: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.8125rem;
  }
  .route-map__placeholder-icon {
    width: 22px;
    height: 22px;
    opacity: 0.55;
  }
  .route-map__stops {
    list-style: none;
    margin: 0;
    padding: 16px;
  }
  .route-map__stops li {
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
  }
  .route-map__stops li:last-child {
    border-bottom: 0;
  }
  .route-map__stops .sub {
    color: var(--muted);
  }
</style>
