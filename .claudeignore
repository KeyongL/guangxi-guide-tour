# ================================
# .claudeignore — Claude Code 不读这些文件
# 语法与 .gitignore 相同
# ================================

# 安全：凭证和密钥（必须，光 .gitignore 不够）
.env
.env.*
*.pem
*.key
secrets/
credentials/

# 大型依赖（读了没用只占上下文）
node_modules/
.venv/
venv/
__pycache__/

# 构建产物（读源码即可）
dist/
build/
.next/
out/
*.min.js
*.min.css

# 二进制和媒体文件（Claude 读不了）
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.webp
*.svg
*.mp4
*.mp3
*.zip
*.tar.gz

# 日志（太长，噪音）
*.log
logs/

# 测试覆盖率报告
coverage/

# 原型和临时文件
prototype/

# ================================
# 仍然让 Claude 读的重要文件
# （不在此列表，即 Claude 默认会读）
# ================================
# CLAUDE.md、src/、tests/、docs/、
# feature_list.json、config.yaml、
# package.json、requirements.txt 等
