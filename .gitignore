# ================================
# 安全：永远不进 git 的文件
# ================================

# 凭证和密钥（最重要）
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ================================
# 运行时产生的文件
# ================================

# 依赖
node_modules/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# 构建产物
dist/
build/
.next/
out/
*.egg-info/

# 日志
*.log
logs/
npm-debug.log*

# 临时文件
*.tmp
*.temp
.DS_Store
Thumbs.db

# ================================
# Claude Code 个人文件
# ================================

# 个人本地笔记（不分享给团队）
CLAUDE.local.md
.claude/settings.local.json

# 原型代码（验证用的，不是产品代码）
prototype/

# 视觉原型（生成产物，不用版本控制）
mockups/

# ================================
# 测试和覆盖率
# ================================

coverage/
.nyc_output/
*.lcov

# ================================
# IDE
# ================================

.vscode/
.idea/
*.swp
*.swo
